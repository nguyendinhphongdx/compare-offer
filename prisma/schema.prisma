generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Shared User table (managed by LMS, read/upsert only from OfferLens)
model User {
  id           String  @id @default(cuid())
  supabaseId   String  @unique
  email        String  @unique
  name         String?
  avatar       String?
  useSystemKey Boolean @default(true) @map("use_system_key")

  @@map("User")
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  provider  String   // gemini, openai, claude
  label     String?  // user-friendly name, e.g. "Gemini cá nhân"
  apiKey    String   @map("api_key")
  isDefault Boolean  @default(false) @map("is_default")
  isValid   Boolean? @map("is_valid") // null = untested, true/false = tested
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, provider])
  @@map("of_api_keys")
}

model Offer {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  companyName   String   @map("company_name")
  position      String
  logo          String?
  color         String   @default("#6366f1")
  date          String?
  status        String   @default("pending")
  isCurrent     Boolean  @default(false) @map("is_current")
  overallRating Float?   @map("overall_rating")
  values        Json     @default("[]")
  notes         String?
  deadline      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("of_offers")
}

model CustomCriterion {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  category    String   @default("custom")
  description String?
  type        String   @default("text")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("of_custom_criteria")
}

model SharedComparison {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String?
  offers    Json     // snapshot of selected offers
  criteria  Json     // snapshot of criteria used
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  @@index([userId])
  @@map("of_shared_comparisons")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String
  content   String
  timestamp DateTime @default(now())

  @@index([userId])
  @@map("of_chat_messages")
}
